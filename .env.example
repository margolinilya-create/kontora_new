# Kontora — переменные окружения
#
# Скопируй этот файл в `.env.local` и заполни реальные значения.
# `.env.local` в .gitignore и никогда не коммитится.

# === Resend (отправка email с форм) ===
# Получить ключ: https://resend.com/api-keys (бесплатно до 3000 писем/мес)
# Если ключ не задан — формы валидируют вход и показывают success UI,
# но письма не уходят (с warning в логах сервера).
RESEND_API_KEY=

# От какого адреса отправлять. Для production нужно верифицировать
# собственный домен в Resend. До верификации можно оставить дефолт
# onboarding@resend.dev — письма будут приходить с него.
RESEND_FROM=onboarding@resend.dev

# Куда приходят заявки (почта владельца / отдела продаж).
RESEND_TO=hello@kontora.su

# === Аналитика (подключение в M6) ===
# ID счётчика Яндекс.Метрики (цифры). Если пусто — не подгружается.
NEXT_PUBLIC_METRIKA_ID=

# PostHog (опционально — funnel + session recording).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
