{
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": ["boundaries", "@typescript-eslint"],
  "settings": {
    "boundaries/include": ["app/**/*", "components/**/*", "lib/**/*"],
    "boundaries/elements": [
      { "type": "app", "pattern": "app/**/*" },
      { "type": "lib", "pattern": "lib/**/*" },
      { "type": "ui", "pattern": "components/ui/**/*" },
      { "type": "brand", "pattern": "components/brand/**/*" },
      { "type": "sections", "pattern": "components/sections/**/*" },
      { "type": "calculator", "pattern": "components/calculator/**/*" },
      { "type": "forms", "pattern": "components/forms/**/*" },
      { "type": "providers", "pattern": "components/providers/**/*" }
    ]
  },
  "rules": {
    "boundaries/element-types": [
      "error",
      {
        "default": "disallow",
        "rules": [
          { "from": "app", "allow": ["app", "lib", "ui", "brand", "sections", "calculator", "forms", "providers"] },
          { "from": "lib", "allow": ["lib"] },
          { "from": "ui", "allow": ["ui", "lib"] },
          { "from": "brand", "allow": ["brand", "ui", "lib"] },
          { "from": "sections", "allow": ["sections", "brand", "ui", "lib", "forms", "calculator"] },
          { "from": "calculator", "allow": ["calculator", "ui", "brand", "lib"] },
          { "from": "forms", "allow": ["forms", "ui", "brand", "lib"] },
          { "from": "providers", "allow": ["providers", "lib"] }
        ]
      }
    ],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "Literal[value=/^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$/]",
        "message": "Запрещены raw hex цвета. Используйте CSS vars из globals.css или токены из lib/tokens.ts."
      }
    ],
    "@typescript-eslint/consistent-type-imports": ["error", { "prefer": "type-imports" }],
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": [
        "app/global-error.tsx",
        "app/icon.tsx",
        "app/apple-icon.tsx",
        "app/opengraph-image.tsx",
        "app/**/opengraph-image.tsx",
        "app/layout.tsx",
        "app/manifest.ts",
        "lib/tokens.ts",
        "lib/email/templates/**/*"
      ],
      "rules": {
        "no-restricted-syntax": "off"
      }
    },
    {
      "files": ["scripts/**/*", "tests/**/*", "vitest.config.ts"],
      "rules": {
        "boundaries/element-types": "off",
        "no-restricted-syntax": "off"
      }
    }
  ]
}
